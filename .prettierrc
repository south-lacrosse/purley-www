{
	"endOfLine": "auto",
	"printWidth": 100,
	"semi": true,
	"singleQuote": true,
	"tabWidth": 4,
	"trailingComma": "es5",
	"useTabs": true,
	"plugins": ["prettier-plugin-astro"],
	"overrides": [
		{
			"files": ["*.md", "*.mdx", "*.toml", "*.yml"],
			"options": {
				"useTabs": false
			}
		},
		{
			"files": ["**/*.astro"],
			"options": {
				"parser": "astro"
			}
		}
	]
}
